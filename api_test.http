@contentType = application/json
@requestID = Test02

### ==========================================
### 1. KATEGORI (CATEGORIES)
### ==========================================

# Ambil semua kategori (Electronics, Furniture, Stationery)
GET {{baseUrl}}/categories
Authorization: Bearer {{token}}
X-Request-Id: {{requestID}}

###

# Ambil kategori per ID
GET {{baseUrl}}/categories/2
Authorization: Bearer {{token}}
X-Request-Id: {{requestID}}

###

# Tambah kategori baru
POST {{baseUrl}}/categories
Content-Type: {{contentType}}
Authorization: Bearer {{token}}
X-Request-Id: {{requestID}}

{
    "name": "Printer",
    "Description": "Printer"    
}

###

# Update kategori
PUT {{baseUrl}}/categories/5
Content-Type: {{contentType}}
Authorization: Bearer {{token}}
X-Request-Id: {{requestID}}

{
    "name": "Printer2",
    "Description": "Printer"  
}

###

# Delete kategori
DELETE  {{baseUrl}}/categories/5
Content-Type: {{contentType}}
Authorization: Bearer {{token}}
X-Request-Id: {{requestID}}

###

### ==========================================
### 2. BARANG (ITEMS)
### ==========================================

# Ambil semua daftar barang beserta stoknya
# GET {{baseUrl}}/items?page=1&limit=10&name=lo&category=1
GET {{baseUrl}}/items?page=1&limit=10&category_id=1
Authorization: Bearer {{token}}
X-Request-Id: {{requestID}}

###

# Cari barang spesifik (Misal: MacBook Pro M2)
# Sesuaikan ID 1 sesuai hasil insert di DB
GET {{baseUrl}}/items/1
Authorization: Bearer {{token}}
X-Request-Id: {{requestID}}

###

# Export csv, semua daftar barang beserta stoknya
GET {{baseUrl}}/items/export
Authorization: Bearer {{token}}
X-Request-Id: {{requestID}}

###

# Tambah barang baru (Contoh: Monitor) ke kategori Electronics (ID: 1)
POST {{baseUrl}}/items/create
Content-Type: {{contentType}}
Authorization: Bearer {{token}}
X-Request-Id: {{requestID}}

{
    "category_id": 1,
    "sku": "ELC-MON-003",
    "name": "Dell UltraSharp 27-inch",
    "price": 8500000.00,
    "stock": 5
}

###

# Update barang
PUT {{baseUrl}}/items/11
Content-Type: {{contentType}}
Authorization: Bearer {{token}}
X-Request-Id: {{requestID}}

{
    "category_id": 1,    
    "name": "Dell UltraSharp 27-inch ver 2",
    "price": 8500000.00
}

###

### ==========================================
### 3. RIWAYAT STOK (STOCK LOGS)
### ==========================================

# Lihat riwayat keluar/masuk barang tertentu (Item ID: 2)
# GET {{baseUrl}}/items/stock-logs?page=1&limit=10&item_id=1&type=IN
GET {{baseUrl}}/items/stock-logs?page=1&limit=10
Authorization: Bearer {{token}}
X-Request-Id: {{requestID}}

###

# Catat transaksi stok baru (OUT/Barang Keluar)
# Simulasi: Barang terjual atau rusak (seperti data dummy-mu)
# "reason": "Masuk barang baru"
# "reason": "Sold to customer - Order #INV001"
POST {{baseUrl}}/items/update-stock
Content-Type: {{contentType}}
Authorization: Bearer {{token}}
X-Request-Id: {{requestID}}

{
    "item_id": 4,
    "type": "OUT",
    "quantity": 1,
    "reason": "Sold to customer - Order #INV001"
}

###

# Delete barang (soft delete)- ADMIN ONLY
DELETE  {{baseUrl}}/items/2
Content-Type: {{contentType}}
Authorization: Bearer {{token}}
X-Request-Id: {{requestID}}

###

### ==========================================
### 4. AUTHENTICATION TEST
### ==========================================

# Test request tanpa API Key (Harusnya Error 401 Unauthorized)
GET {{baseUrl}}/items
Accept: {{contentType}}
